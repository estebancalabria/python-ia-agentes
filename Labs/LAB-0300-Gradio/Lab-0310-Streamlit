st.title("🔠 Convertidor de Texto a Mayúsculas")

texto = st.text_input("Introduce un texto:")

if texto:
    st.success(texto.upper())

# Ejecutar Streamlit con ngrok
from pyngrok import ngrok
import subprocess
import time

!pkill streamlit

process = subprocess.Popen(["streamlit", "run", "app.py"])
time.sleep(5)

public_url = ngrok.connect(8501)
print("🚀 Tu aplicación está disponible en:", public_url)
```

